<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<Title>PitSeeder</Title>
		<Description>Command-line seeder for JsonPit data stores.</Description>
		<Version>0.5.0</Version>
		<PackageId>PitSeeder</PackageId>
		<Author>Rainer Burkhardt</Author>
		<PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageProjectUrl>https://github.com/Burkhardt/PitSeeder</PackageProjectUrl>
		<RepositoryUrl>https://github.com/Burkhardt/PitSeeder.git</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PublishRepositoryUrl>true</PublishRepositoryUrl>
		<PackageReleaseNotes>0.5.0: built against local source references for OsLib 3.7.3 and JsonPit 3.7.3 while the corresponding NuGet packages are not yet published.</PackageReleaseNotes>
		<OutputType>Exe</OutputType>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<IsPackable>true</IsPackable>
		<PackAsTool>true</PackAsTool>
		<ToolCommandName>pits</ToolCommandName>
		<PackageOutputPath>../artifacts/nuget</PackageOutputPath>
		<PackageTags>jsonpit;pit;cli;tool</PackageTags>
		<DeployToUsrLocalBin>false</DeployToUsrLocalBin>
		<EnableCloudSampleSync>false</EnableCloudSampleSync>
		<RAIkeepRoot Condition="'$(RAIkeepRoot)' == '' and Exists('../../GitHub/RAIkeep/JsonPit/JsonPit.csproj')">../../GitHub/RAIkeep</RAIkeepRoot>
		<JsonPitProjectPath Condition="'$(RAIkeepRoot)' != '' and Exists('$(RAIkeepRoot)/JsonPit/JsonPit.csproj')">$(RAIkeepRoot)/JsonPit/JsonPit.csproj</JsonPitProjectPath>
		<OsLibProjectPath Condition="'$(RAIkeepRoot)' != '' and Exists('$(RAIkeepRoot)/OsLib/OsLib.csproj')">$(RAIkeepRoot)/OsLib/OsLib.csproj</OsLibProjectPath>
		<UseLocalRAIkeepSources Condition="'$(UseLocalRAIkeepSources)' == '' and '$(JsonPitProjectPath)' != '' and '$(OsLibProjectPath)' != ''">true</UseLocalRAIkeepSources>
		<UseLocalRAIkeepSources Condition="'$(UseLocalRAIkeepSources)' == ''">false</UseLocalRAIkeepSources>
		<JsonPitPackageVersion Condition="'$(JsonPitPackageVersion)' == ''">3.7.2</JsonPitPackageVersion>
		<OsLibPackageVersion Condition="'$(OsLibPackageVersion)' == ''">3.7.2</OsLibPackageVersion>

		<CloudSamplePath Condition="'$(CloudSamplePath)' == ''"></CloudSamplePath>
	</PropertyGroup>

	<ItemGroup>
		<None Include="../README.md" Pack="true" PackagePath="\" Link="README.md" />
	</ItemGroup>

	<Target Name="ValidateLocalRAIkeepSources"
		BeforeTargets="Restore"
		Condition="'$(UseLocalRAIkeepSources)' == 'true'">
		<Error Condition="'$(JsonPitProjectPath)' == ''"
			Text="UseLocalRAIkeepSources=true requires a JsonPit project checkout. Set /p:RAIkeepRoot=/path/to/RAIkeep." />
		<Error Condition="'$(OsLibProjectPath)' == ''"
			Text="UseLocalRAIkeepSources=true requires an OsLib project checkout. Set /p:RAIkeepRoot=/path/to/RAIkeep." />
	</Target>

	<ItemGroup Condition="'$(UseLocalRAIkeepSources)' == 'true'">
		<ProjectReference Include="$(JsonPitProjectPath)" />
		<ProjectReference Include="$(OsLibProjectPath)" />
	</ItemGroup>

	<ItemGroup Condition="'$(UseLocalRAIkeepSources)' != 'true'">
		<PackageReference Include="JsonPit" Version="$(JsonPitPackageVersion)" />
		<PackageReference Include="OsLibCore" Version="$(OsLibPackageVersion)" />
	</ItemGroup>

	<Target Name="SyncSamplesToCloud"
		AfterTargets="Build"
		Condition="'$(EnableCloudSampleSync)' == 'true' and '$(CloudSamplePath)' != '' and ('$(IsPackable)' != 'true' or '$(IsPacking)' != 'true')">
		<ItemGroup>
			<SampleFiles Include="sample\**\*.*" />
		</ItemGroup>

		<MakeDir Directories="$(CloudSamplePath)" />

		<Message Importance="High" Text="--- JsonPit Sync: Found @(SampleFiles->Count()) files ---" />

		<Copy
			SourceFiles="@(SampleFiles)"
			DestinationFolder="$(CloudSamplePath)\%(RecursiveDir)"
			SkipUnchangedFiles="true" />
	</Target>

	<Target Name="DeployPublishedFilesToUsrLocalBin"
		AfterTargets="Publish"
		Condition="'$(DeployToUsrLocalBin)' == 'true'
					 and '$(OS)' != 'Windows_NT'
					 and '$(RuntimeIdentifier)' == 'osx-arm64'
					 and '$(SelfContained)' == 'true'
					 and '$(PublishSingleFile)' == 'true'">
		<ItemGroup>
			<DeployFiles Include="$(PublishDir)$(AssemblyName)"
				Condition="Exists('$(PublishDir)$(AssemblyName)')" />
			<DeployFiles Include="$(PublishDir)$(AssemblyName).pdb"
				Condition="Exists('$(PublishDir)$(AssemblyName).pdb')" />
		</ItemGroup>

		<Message Importance="high"
			Text="Deploying @(DeployFiles->'%(Filename)%(Extension)', ', ') to /usr/local/bin" />
		<Copy SourceFiles="@(DeployFiles)"
			DestinationFolder="/usr/local/bin"
			SkipUnchangedFiles="true" />
	</Target>

</Project>
