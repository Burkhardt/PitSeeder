{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build pits",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"${workspaceFolder}/pits/pits.csproj"
			],
			"group": "build",
			"problemMatcher": "$msCompile"
		},
		{
			"label": "build pits (local RAIkeep)",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"${workspaceFolder}/pits/pits.csproj",
				"-p:UseLocalRAIkeepSources=true",
				"-p:RAIkeepRoot=/Users/RSB/Projects/GitHub/RAIkeep"
			],
			"group": "build",
			"problemMatcher": "$msCompile"
		}
	]
}