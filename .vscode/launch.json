	"version": "0.2.0",
	"configurations": [

		{
			"version": "0.2.0",
			"configurations": [
				{
					"name": "Debug installed pits ",
					"type": "coreclr",
					"request": "launch",
					"program": "/usr/local/bin/pits",
					"cwd": "/Users/RSB/Projects/PitSeeder/pits",
					"args": [],
					"console": "integratedTerminal",
					"stopAtEntry": true,
					"justMyCode": true,
					"requireExactSource": true,
					"symbolOptions": {
						"searchPaths": [
							"/usr/local/bin"
						]
					}
				}
			]
		},
		{
			"name": "pits: Bulk Seed Sample",
			"type": "coreclr",
			"request": "launch",
			"preLaunchTask": "build pits",
			"program": "${workspaceFolder}/pits/bin/Debug/net10.0/pits.dll",
			"cwd": "${workspaceFolder}/pits",
			"args": [
				"-wwwa",
				"${workspaceFolder}/pits/sample"
			],
			"console": "integratedTerminal"
		},
		{
			"name": "pits: Single Person Seed",
			"type": "coreclr",
			"request": "launch",
			"preLaunchTask": "build pits",
			"program": "${workspaceFolder}/pits/bin/Debug/net10.0/pits.dll",
			"cwd": "${workspaceFolder}/pits",
			"args": [
				"-pit",
				"Person",
				"-file",
				"${workspaceFolder}/pits/sample/Person.json5"
			],
			"console": "integratedTerminal"
		}
	]
}